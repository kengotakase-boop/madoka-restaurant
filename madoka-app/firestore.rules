// このファイルは参照用です。実際に有効なのは Firebase Console に公開された内容。
// 変更時は Firebase Console → Firestore Database → ルール に貼り付けて公開してください。
//
// 現方針: 家族共通台帳（ログイン撤去移行中）。dishes は誰でも read/create/update、
// delete は依然禁止。家族だけが URL を知っている前提の obscurity 運用。
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /dishes/{dishId} {
      allow read, create, update: if true;
      allow delete: if false;
    }
  }
}
